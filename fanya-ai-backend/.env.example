# AI 服务配置示例
# 复制为 .env 并根据需要修改

# ===== AI 提供商选择 =====
# 选项: mock, openai, zhipu, aliyun, xfyun
# 推荐使用: zhipu (智谱 GLM，国内响应快)
AI_PROVIDER=zhipu

# ===== 智谱 GLM API 配置 =====
# 文档: https://open.bigmodel.cn/
# 获取 API Key: https://open.bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=fb669be59e3047b8835481430860d04c.AIKnxPwus1awK4RM

# ===== OpenAI 配置 (可选) =====
# 获取地址: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ===== 阿里通义千问配置 (可选) =====
# 获取地址: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-aliyun-key-here
# 课件点击配图时调用通义千问视觉（如 qwen-vl-plus、qwen-vl-max）
QWEN_VL_MODEL=qwen-vl-plus

# ===== 讯飞星火配置 (可选) =====
# 获取地址: https://console.xfyun.cn/services/spark
XFYUN_APPID=your-appid-here
XFYUN_API_SECRET=your-api-secret-here
XFYUN_API_KEY=your-api-key-here

# ===== 数据库配置 =====
DATABASE_URL=mysql+pymysql://root:password@localhost/fanya_ai

# ===== Flask 配置 =====
FLASK_ENV=development
FLASK_DEBUG=True
